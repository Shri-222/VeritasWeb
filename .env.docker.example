# Public Supabase settings are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase settings. Do not commit real values.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Private artifact storage.
SUPABASE_STORAGE_BUCKET=captures
STORAGE_PROVIDER=supabase

# Scheduled capture protection.
CRON_SECRET=

# Public app URLs used in links and deployment metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime settings.
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
