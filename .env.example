# Public Supabase settings are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase settings. Never expose or commit real secret values.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
CRON_SECRET=

# Current screenshot storage bucket name used by the capture API.
SUPABASE_STORAGE_BUCKET=captures
