# Public Supabase settings are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase settings.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
CRON_SECRET=

# Private storage bucket name used for screenshot and HTML artifacts.
SUPABASE_STORAGE_BUCKET=captures

# These are server-enforced defaults when omitted.
BETA_MAX_MONITORS_PER_USER=5
BETA_MAX_CAPTURES_PER_DAY=20
BETA_MAX_BUNDLE_CAPTURES=25

# Leave blank to keep them disabled.
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEBHOOK_SIGNING_SECRET=
EMAIL_PROVIDER=
RESEND_API_KEY=
EMAIL_FROM=
STORAGE_PROVIDER=supabase
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
GEMINI_API_KEY=
GEMINI_MODEL=
